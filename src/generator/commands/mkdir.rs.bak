use crate::ast::*;
use crate::generator::Generator;

pub fn generate_mkdir_command(generator: &mut Generator, cmd: &SimpleCommand) -> String {
    let mut output = String::new();
    
    // mkdir command syntax: mkdir [options] directory...
    let mut create_parents = false;
    let mut directories = Vec::new();
    
    // Parse mkdir options
    for arg in &cmd.args {
        if let Word::Literal(arg_str, _) = arg {
            match arg_str.as_str() {
                "-p" | "--parents" => create_parents = true,
                _ => {
                    if !arg_str.starts_with('-') {
                        directories.push(generator.word_to_perl(arg));
                    }
                }
            }
        } else {
            directories.push(generator.word_to_perl(arg));
        }
    }
    
    if directories.is_empty() {
        output.push_str("croak \"mkdir: missing operand\\n\";\n");
    } else {
        if !generator.declared_locals.contains("err") {
            output.push_str("my $err;\n");
            generator.declared_locals.insert("err".to_string());
        }
        
        for dir in &directories {
            let quoted_dir = if dir.starts_with('"') || dir.starts_with("'") {
                dir.clone()
            } else {
                format!("\"{}\"", dir)
            };
            if create_parents {
                output.push_str(&format!("if (!-d {}) {{\n", quoted_dir));
                output.push_str(&format!("make_path({}, {{error => \\$err}});\n", quoted_dir));
                output.push_str("if (@{$err}) {\n");
                output.push_str(&format!("croak \"mkdir: cannot create directory {}: $err->[0]\\n\";\n", dir));
                output.push_str("} else {\n");
                output.push_str(&format!("# print \"mkdir: created directory {}\\n\";\n", quoted_dir));
                output.push_str("}\n");
                output.push_str("} else {\n");
                // mkdir -p is silent when directory already exists (matches shell behavior)
                output.push_str("}\n");
            } else {
                output.push_str(&format!("if (!-d {}) {{\n", quoted_dir));
                output.push_str(&format!("if (mkdir {}) {{\n", quoted_dir));
                output.push_str(&format!("# print \"mkdir: created directory {}\\n\";\n", quoted_dir));
                output.push_str("$CHILD_ERROR = 0;\n");
                output.push_str("} else {\n");
                output.push_str("$CHILD_ERROR = 1;\n");
                output.push_str(&format!("# croak \"mkdir: cannot create directory {}: $ERRNO\\n\";\n", dir));
                output.push_str("}\n");
                output.push_str("} else {\n");
                output.push_str("$CHILD_ERROR = 1;\n");
                output.push_str("}\n");
                output.push_str("q{};");
            }
        }
    }
    
    output
}
