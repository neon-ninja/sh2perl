#!/bin/bash

echo "To run this test: ./fail FAILING_TEST_PREFIX"
echo "To run a specific test: ./fail TEST_PREFIX"
echo "Examples: ./fail 062_02, ./fail 044, ./fail find"

export LOCALE=C
export LC_COLLATE=C

# Add Git usr/bin to the beginning of PATH for proper ls command
export PATH="/c/Strawberry/perl/bin:/c/Program Files/Git/usr/bin:$PATH"

#git stash push examples ./fail.bat ./fail ./src/main.rs src/testing.rs src/execution.rs
if ! cargo run --bin debashc -- fail "$@" --perl-critic
then
    echo "debashc failed, aborting other commands"
    exit 1
fi


# Run test_purify.pl first and only continue if it passes
echo "Running test_purify.pl --next --verbose..."
if ! perl test_purify.pl --next --verbose; then
    echo "test_purify.pl failed, aborting other commands"
    exit 1
fi

echo "test_purify.pl passed, continuing with other commands..."


