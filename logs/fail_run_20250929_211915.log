#!/usr/bin/env perl
use strict;
use warnings;
use Carp;
use English qw( -no_match_vars );
use locale;
use IPC::Open3;

my $main_exit_code = 0;
my $ls_success = 0;
our $CHILD_ERROR;

print "=== System Utilities ===\n";
my $formatted_date = do { use POSIX qw(strftime); strftime("%Y-%m-%d", localtime); };
print "Formatted date: $formatted_date\n";
my $yes_result = do {
my $head_line_count = 0;
my $output_0 = q{};
while (1) {
    my $line = "Hello";
    # yes doesn't support line-by-line processing
    if ($head_line_count < 3) {
        if ($head_line_count > 0) { $output_0 .= "\n"; }
        $output_0 .= $line;
        ++$head_line_count;
    } else {
        $line = q{}; # Clear line to prevent printing
        last; # Break out of the yes loop when head limit is reached
    }
}
$output_0

};
print "Yes command result:\n";
print $yes_result;
if (!($yes_result =~ /\n$/msx)) { print "\n"; }


