echo "Bash path: $bash_path"

# yes command with backticks
#PERL_MUST_NOT_CONTAIN `yes
yes_result=`yes "Hello" | head -3`
echo "Yes command result:"
echo "$yes_result"

echo "=== System Utilities Complete ==="



