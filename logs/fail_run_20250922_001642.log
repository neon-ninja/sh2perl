    my $line = "Hello";
    # yes doesn't support line-by-line processing
    if ($head_line_count < 3) {
        $output_0 .= $line . "\n";
        ++$head_line_count;
    } else {
        $line = q{}; # Clear line to prevent printing
    }
}
$output_0

};
print "Yes command result:\n";
print $yes_result;
if (!($yes_result =~ /\n$/msx)) { print "\n"; }
print "=== System Utilities Complete ===\n";


