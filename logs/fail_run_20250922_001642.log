use locale;
use IPC::Open3;

my $main_exit_code = 0;
my $ls_success = 0;
our $CHILD_ERROR;

print "=== System Utilities ===\n";
my $formatted_date = do { use POSIX qw(strftime); strftime('%Y-%m-%d %H', localtime); };
my $timestamp = do { use POSIX qw(strftime); strftime('%rms', localtime); };
print "Timestamp: $timestamp\n";
print "Formatted date: $formatted_date\n";
my $time_result = do {
    my $cmd_result_0 = do { use Time::HiRes qw(gettimeofday tv_interval);
my $start_time = [gettimeofday];
system "sleep 1";
my $end_time = [gettimeofday];
my $elapsed = tv_interval($start_time, $end_time);
my $time_output = sprintf "real %.3fs\nuser 0.000s\nsys 0.000s\n", $elapsed;
print STDERR $time_output;
$time_output;
 };
    chomp $cmd_result_0;
    $cmd_result_0;
};
print "Time result: $time_result\n";
my $sleep_duration = (q{2});
print "Sleeping for $sleep_duration seconds...\n";
