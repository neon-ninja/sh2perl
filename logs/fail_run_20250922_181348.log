#!/usr/bin/env perl
use strict;
use warnings;
use Carp;
use English qw( -no_match_vars );
use locale;
use IPC::Open3;

my $main_exit_code = 0;
my $ls_success = 0;
our $CHILD_ERROR;

print "=== File and Directory Operations ===\n";
my $file_list = do {
    my $cmd_result_1 = do {
    my @ls_files_0 = ();
    if (-f q{.}) {
        push @ls_files_0, q{.};
    } elsif (-d q{.}) {
        if (opendir my $dh, q{.}) {
            while (my $file = readdir $dh) {
                next if $file =~ /^__tmp_.*[.]pl$/msx;
                push @ls_files_0, $file;
            }
            closedir $dh;
            @ls_files_0 = sort { lc $a cmp lc $b } @ls_files_0;
        }
    }
    join "\n", @ls_files_0;
};
    chomp $cmd_result_1;
    $cmd_result_1;
};
print "File listing:\n";
print $file_list;
if (!($file_list =~ /\n$/msx)) { print "\n"; }
my $found_files = do {
    my $cmd_result_3 = do {
    use File::Find;
    use File::Basename;
    my @files_2 = ();
    my $start_2 = q{.};
    sub find_files_2 {
        my $file_2 = $File::Find::name;
        return unless -f $file_2;
        return unless basename($file_2) =~ m/^.*.sh$/xms;
        push @files_2, $file_2;
    }
    find(\&find_files_2, $start_2);
    join "\n", @files_2;
};
    chomp $cmd_result_3;
    $cmd_result_3;
};
print "Found shell scripts:\n";
print $found_files;
if (!($found_files =~ /\n$/msx)) { print "\n"; }


