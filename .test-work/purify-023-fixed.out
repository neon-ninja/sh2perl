#!/usr/bin/perl


print "=== Example 023: Basic mv command ===\n";

open(my $fh, '>', 'test_mv_source.txt') or die "Cannot create test file: $!\n";
print $fh "This is a test file for moving\n";
print $fh "It has multiple lines\n";
print $fh "To demonstrate mv functionality\n";
close($fh);

do {
use Carp;
use English qw(-no_match_vars $ERRNO $EVAL_ERROR $INPUT_RECORD_SEPARATOR $OS_ERROR $PROGRAM_NAME);
use File::Path qw(make_path remove_tree);
use File::Path qw(make_path);
my $err;
if ( !-d "test_mv_dir" ) {
    make_path( "test_mv_dir", { error => \$err } );
    if ( @{$err} ) {
        croak "mkdir: cannot create directory " . "test_mv_dir" . ": $err->[0]\n";
    }
}

};

print "Using " . "sys" . "tem" . "() to call mv (move file):\n";
do {
use English qw(-no_match_vars $ERRNO $EVAL_ERROR $INPUT_RECORD_SEPARATOR $OS_ERROR $PROGRAM_NAME);
use File::Path qw(make_path remove_tree);
use File::Copy qw(copy move);
my $mv_cmd = 'mv test_mv_source.txt test_mv_dest.txt';
print qx{$mv_cmd};

};
if (-f "test_mv_dest.txt") {
    print "File moved successfully\n";
    my $content = do { my @files = ('test_mv_dest.txt'); local $INPUT_RECORD_SEPARATOR = undef; join('', map { open my $fh, '<', $_ or die 'cat: ' . $_ . ': ' . $OS_ERROR . "\n"; my $chunk = <$fh>; close $fh or die 'cat: close failed: ' . $OS_ERROR . "\n"; $chunk; } @files) }
;
    print "Content: $content";
} else {
    print "File move failed\n";
}

print "\nmv with verbose (-v):\n";
do {
use English qw(-no_match_vars $ERRNO $EVAL_ERROR $INPUT_RECORD_SEPARATOR $OS_ERROR $PROGRAM_NAME);
use File::Path qw(make_path remove_tree);
use File::Copy qw(copy move);
my $mv_cmd = 'mv -v test_mv_dest.txt test_mv_verbose.txt';
print qx{$mv_cmd};

};

print "\nmv with force (-f):\n";
my $mv_force = do {
        local $CHILD_ERROR = 0;
        my $eval_result = eval {
            my $mv_cmd = 'mv -f test_mv_verbose.txt test_mv_force.txt'; 
            local $CHILD_ERROR = 0;
            1;
        };
        if ( !$eval_result ) {
            local $CHILD_ERROR = 256;
        }
        q{};
}
;
if (-f "test_mv_force.txt") {
    print "File moved with force\n";
}

print "\nmv with interactive (-i):\n";
do {
use English qw(-no_match_vars $ERRNO $EVAL_ERROR $INPUT_RECORD_SEPARATOR $OS_ERROR $PROGRAM_NAME);
use File::Path qw(make_path remove_tree);
use File::Copy qw(copy move);
my $mv_cmd = 'mv -i test_mv_force.txt test_mv_interactive.txt';
print qx{$mv_cmd};

};

print "\nmv with backup (-b):\n";
my $mv_backup = do {
        local $CHILD_ERROR = 0;
        my $eval_result = eval {
            my $mv_cmd = 'mv -b test_mv_interactive.txt test_mv_backup.txt'; 
            local $CHILD_ERROR = 0;
            1;
        };
        if ( !$eval_result ) {
            local $CHILD_ERROR = 256;
        }
        q{};
}
;
if (-f "test_mv_backup.txt") {
    print "File moved with backup\n";
}

print "\nmv with suffix (--suffix=.bak):\n";
do {
use English qw(-no_match_vars $ERRNO $EVAL_ERROR $INPUT_RECORD_SEPARATOR $OS_ERROR $PROGRAM_NAME);
use File::Path qw(make_path remove_tree);
use File::Copy qw(copy move);
my $mv_cmd = 'mv --suffix=.bak test_mv_backup.txt test_mv_suffix.txt';
print qx{$mv_cmd};

};

print "\nmv with no target directory (-T):\n";
my $mv_no_target = do {
        local $CHILD_ERROR = 0;
        my $eval_result = eval {
            my $mv_cmd = 'mv -T test_mv_suffix.txt test_mv_no_target.txt'; 
            local $CHILD_ERROR = 0;
            1;
        };
        if ( !$eval_result ) {
            local $CHILD_ERROR = 256;
        }
        q{};
}
;
if (-f "test_mv_no_target.txt") {
    print "File moved with no target directory\n";
}

print "\nmv with update (-u):\n";
do {
use English qw(-no_match_vars $ERRNO $EVAL_ERROR $INPUT_RECORD_SEPARATOR $OS_ERROR $PROGRAM_NAME);
use File::Path qw(make_path remove_tree);
use File::Copy qw(copy move);
my $mv_cmd = 'mv -u test_mv_no_target.txt test_mv_update.txt';
print qx{$mv_cmd};

};

print "\nmv with no clobber (-n):\n";
my $mv_no_clobber = do {
        local $CHILD_ERROR = 0;
        my $eval_result = eval {
            my $mv_cmd = 'mv -n test_mv_update.txt test_mv_no_clobber.txt'; 
            local $CHILD_ERROR = 0;
            1;
        };
        if ( !$eval_result ) {
            local $CHILD_ERROR = 256;
        }
        q{};
}
;
if (-f "test_mv_no_clobber.txt") {
    print "File moved with no clobber\n";
}

print "\nmv with strip trailing slashes (--strip-trailing-slashes):\n";
do {
use English qw(-no_match_vars $ERRNO $EVAL_ERROR $INPUT_RECORD_SEPARATOR $OS_ERROR $PROGRAM_NAME);
use File::Path qw(make_path remove_tree);
use File::Copy qw(copy move);
my $mv_cmd = 'mv --strip-trailing-slashes test_mv_no_clobber.txt test_mv_strip.txt';
print qx{$mv_cmd};

};

print "\nmv with multiple files:\n";
do {
use Carp;
use English qw(-no_match_vars $ERRNO $EVAL_ERROR $INPUT_RECORD_SEPARATOR $OS_ERROR $PROGRAM_NAME);
use POSIX qw(time);
if ( -e "test_mv_file1.txt" ) {
    my $current_time = time;
    utime $current_time, $current_time, "test_mv_file1.txt";
}
else {
    if ( open my $fh, '>', "test_mv_file1.txt" ) {
        close $fh or croak "Close failed: $ERRNO";
    }
    else {
        croak "touch: cannot create ", "test_mv_file1.txt",
          ": $ERRNO\n";
    }
}

};
do {
use Carp;
use English qw(-no_match_vars $ERRNO $EVAL_ERROR $INPUT_RECORD_SEPARATOR $OS_ERROR $PROGRAM_NAME);
use POSIX qw(time);
if ( -e "test_mv_file2.txt" ) {
    my $current_time = time;
    utime $current_time, $current_time, "test_mv_file2.txt";
}
else {
    if ( open my $fh, '>', "test_mv_file2.txt" ) {
        close $fh or croak "Close failed: $ERRNO";
    }
    else {
        croak "touch: cannot create ", "test_mv_file2.txt",
          ": $ERRNO\n";
    }
}

};
my $mv_multi = do {
        local $CHILD_ERROR = 0;
        my $eval_result = eval {
            my $mv_cmd = 'mv test_mv_file1.txt test_mv_file2.txt test_mv_dir/'; 
            local $CHILD_ERROR = 0;
            1;
        };
        if ( !$eval_result ) {
            local $CHILD_ERROR = 256;
        }
        q{};
}
;
if (-f "test_mv_dir/test_mv_file1.txt" && -f "test_mv_dir/test_mv_file2.txt") {
    print "Multiple files moved successfully\n";
}

print "\nmv with preserve all (-a):\n";
do {
use Carp;
use English qw(-no_match_vars $ERRNO $EVAL_ERROR $INPUT_RECORD_SEPARATOR $OS_ERROR $PROGRAM_NAME);
use POSIX qw(time);
if ( -e "test_mv_preserve.txt" ) {
    my $current_time = time;
    utime $current_time, $current_time, "test_mv_preserve.txt";
}
else {
    if ( open my $fh, '>', "test_mv_preserve.txt" ) {
        close $fh or croak "Close failed: $ERRNO";
    }
    else {
        croak "touch: cannot create ", "test_mv_preserve.txt",
          ": $ERRNO\n";
    }
}

};
do {
use English qw(-no_match_vars $ERRNO $EVAL_ERROR $INPUT_RECORD_SEPARATOR $OS_ERROR $PROGRAM_NAME);
use File::Path qw(make_path remove_tree);
use File::Copy qw(copy move);
my $mv_cmd = 'mv -a test_mv_preserve.txt test_mv_preserve_dest.txt';
print qx{$mv_cmd};

};

unlink('test_mv_strip.txt') if -f 'test_mv_strip.txt';
unlink('test_mv_preserve_dest.txt') if -f 'test_mv_preserve_dest.txt';
do {
use Carp;
use English qw(-no_match_vars $ERRNO $EVAL_ERROR $INPUT_RECORD_SEPARATOR $OS_ERROR $PROGRAM_NAME);
use File::Path qw(make_path remove_tree);
if ( -e "-rf" ) {
    if ( -d "-rf" ) {
        croak "rm: ", "-rf",
          " is a directory (use -r to remove recursively)\n";
    }
    else {
        if ( unlink "-rf" ) {
            $main_exit_code = 0;
        }
        else {
            croak "rm: cannot remove ", "-rf",
              ": $OS_ERROR\n";
        }
    }
}
else {
    local $CHILD_ERROR = 1;
    croak "rm: ", "-rf", ": No such file or directory\n";
}
if ( -e "test_mv_dir" ) {
    if ( -d "test_mv_dir" ) {
        croak "rm: ", "test_mv_dir",
          " is a directory (use -r to remove recursively)\n";
    }
    else {
        if ( unlink "test_mv_dir" ) {
            $main_exit_code = 0;
        }
        else {
            croak "rm: cannot remove ", "test_mv_dir",
              ": $OS_ERROR\n";
        }
    }
}
else {
    local $CHILD_ERROR = 1;
    croak "rm: ", "test_mv_dir", ": No such file or directory\n";
}

};

print "=== Example 023 completed successfully ===\n";
